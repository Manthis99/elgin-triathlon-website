# --- Interest list + ticket storage (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
PORT=4173

# --- Stripe (ticket payments + webhook) ---
# Secret key from https://dashboard.stripe.com/apikeys (use a test key first: sk_test_...)
STRIPE_SECRET_KEY="sk_test_xxx"
# Signing secret shown when you create the webhook endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# --- Resend (branded ticket email) ---
# API key from https://resend.com/api-keys
RESEND_API_KEY="re_xxx"
# Must be a verified sender/domain in Resend
TICKET_FROM_EMAIL="Elgin Triathlon <tickets@yourdomain.com>"
